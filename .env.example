SECRET_KEY=change-this-to-a-random-secret-key
VAULT_KEY=<generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
DATABASE_URL=sqlite:///remote_it.db

# Email (use Gmail App Password or SendGrid SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=support@yourcompany.com

# Set to 'production' on deploy
FLASK_ENV=development
